+/// Handle a completed `OmnixMessage` from the Chat Completions stream.
+///
+/// Returns an `OutputItemResult` that mirrors the semantics of `handle_output_item_done`:
+/// - If the message contains tool calls, queue them for execution and set `needs_follow_up`.
+/// - If the message contains text content, emit it as a completed `AgentMessage` turn item.
+pub(crate) async fn handle_chat_output_item_done(
+    ctx: &mut HandleOutputCtx,
+    msg: codex_protocol::OmnixMessage,
+) -> Result<OutputItemResult> {
+    use codex_protocol::{OmnixMessage, ToolName};
+    use codex_protocol::items::{AgentMessageContent, AgentMessageItem};
+    use codex_protocol::models::ContentItem;
+    use codex_tools::ToolPayload;
+    use crate::tools::router::ToolCall;
+
+    let mut output = OutputItemResult::default();
+
+    match msg {
+        OmnixMessage::Assistant { content, tool_calls, thinking } => {
+            // Record thinking/reasoning content in history for TUI display.
+            if let Some(ref thinking_text) = thinking {
+                if !thinking_text.is_empty() {
+                    let reasoning_item = ResponseItem::Reasoning {
+                        id: uuid::Uuid::new_v4().to_string(),
+                        summary: Vec::new(),
+                        content: Some(vec![
+                            codex_protocol::models::ReasoningItemContent::ReasoningText {
+                                text: thinking_text.clone(),
+                            },
+                        ]),
+                        encrypted_content: None,
+                    };
+                    ctx.sess
+                        .record_conversation_items(
+                            &ctx.turn_context,
+                            std::slice::from_ref(&reasoning_item),
+                        )
+                        .await;
+                }
+            }
+
+            if !tool_calls.is_empty() {
+                // Record the assistant message (with tool calls) in conversation history
+                // as FunctionCall items for compatibility with the existing system.
+                for tc in &tool_calls {
+                    let item = ResponseItem::FunctionCall {
+                        id: None,
+                        name: tc.function.name.clone(),
+                        namespace: None,
+                        arguments: tc.function.arguments.clone(),
+                        call_id: tc.id.clone(),
+                    };
+                    ctx.sess
+                        .record_conversation_items(
+                            &ctx.turn_context,
+                            std::slice::from_ref(&item),
+                        )
+                        .await;
+                }
+
+                // Queue each tool call for execution.
+                for tc in tool_calls {
+                    let call = ToolCall {
+                        tool_name: ToolName::plain(&tc.function.name),
+                        call_id: tc.id,
+                        payload: ToolPayload::Function {
+                            arguments: tc.function.arguments,
+                        },
+                    };
+
+                    tracing::info!(
+                        thread_id = %ctx.sess.conversation_id,
+                        "ChatCompletions ToolCall: {} {}",
+                        call.tool_name,
+                        call.payload.log_payload()
+                    );
+
+                    let cancellation_token = ctx.cancellation_token.child_token();
+                    let tool_future: InFlightFuture<'static> = Box::pin(
+                        ctx.tool_runtime
+                            .clone()
+                            .handle_tool_call(call, cancellation_token),
+                    );
+                    // For now, only support one tool call at a time in the future queue.
+                    // Multiple parallel tool calls will each get their own future.
+                    output.tool_futures.push(tool_future);
+                    output.needs_follow_up = true;
+                }
+            }
+
+            if let Some(text) = content {
+                if !text.is_empty() {
+                    let item_id = uuid::Uuid::new_v4().to_string();
+                    let agent_message = AgentMessageItem {
+                        id: item_id.clone(),
+                        content: vec![AgentMessageContent::Text { text: text.clone() }],
+                        phase: None,
+                        memory_citation: None,
+                    };
+
+                    let turn_item = TurnItem::AgentMessage(agent_message);
+                    ctx.sess
+                        .emit_turn_item_started(&ctx.turn_context, &turn_item)
+                        .await;
+                    ctx.sess
+                        .emit_turn_item_completed(&ctx.turn_context, turn_item)
+                        .await;
+
+                    output.last_agent_message = Some(text.clone());
+
+                    // Record as a ResponseItem::Message for history compatibility.
+                    let history_item = ResponseItem::Message {
+                        id: Some(item_id),
+                        role: "assistant".to_string(),
+                        content: vec![ContentItem::OutputText { text }],
+                        phase: None,
+                    };
+                    ctx.sess
+                        .record_conversation_items(
+                            &ctx.turn_context,
+                            std::slice::from_ref(&history_item),
+                        )
+                        .await;
+                }
+            }
+        }
+        OmnixMessage::System { .. } | OmnixMessage::User { .. } | OmnixMessage::Tool { .. } => {
+            // These should not appear as output items from the model.
+            warn!("Unexpected OmnixMessage variant in ChatOutputItemDone: not an Assistant message");
+        }
+    }
+
+    Ok(output)
+}
